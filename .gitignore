# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist
/assets

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# runtime user uploads (local dev only — production uses object storage)
/public/uploads/*
!/public/uploads/.gitkeep

# temporary files
/tmp/
/temp/

# logs
*.log
logs/

# local database files
*.sqlite
*.db

# capacitor build output
/android/app/build/
/ios/App/build/

# Android signing material (never commit private upload keys)
*.jks
*.keystore
/android/keystore.properties

# IDE
.idea/
.vscode/
*.swp
*.swo

# Local Netlify folder
.netlify
